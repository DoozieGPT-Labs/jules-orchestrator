class TaskState(Enum):
    """Task lifecycle states."""
    PENDING = "pending"
    ISSUE_CREATED = "issue_created"
    JULES_TRIGGERED = "jules_triggered"
    PR_OPENED = "pr_opened"
    COMPLETE = "complete"
    FAILED = "failed"


class SchemaValidator:
    """Basic validation for JULES_MEMORY.json."""
    
    def validate(self, data: Dict) -> Tuple[bool, List[str]]:
        errors = []
        
        if 'version' not in data:
            errors.append("Missing 'version'")
        
        if 'project' not in data:
            errors.append("Missing 'project'")
        elif 'name' not in data.get('project', {}):
            errors.append("Missing 'project.name'")
        
        if 'plan' not in data or 'tasks' not in data.get('plan', {}):
            errors.append("Missing 'plan.tasks'")
        
        if 'execution' not in data:
            errors.append("Missing 'execution'")
        else:
            exec_data = data['execution']
            for field in ['current_task', 'completed_tasks', 'failed_tasks', 'pending_tasks']:
                if field not in exec_data:
                    errors.append(f"Missing 'execution.{field}'")
        
        return len(errors) == 0, errors



# Cost tracking (no deps required)
class CostTracker:
    """Track execution costs."""
    
    def __init__(self, config: Dict, project_dir: Path):
        self.enabled = config.get('enabled', True)
        self.cost_per_hour = config.get('cost_per_hour', 5.0)
        self.records: List[Dict] = []
        self.costs_file = project_dir / 'costs.jsonl'
    
    def start_task(self, task_id: str):
        if not self.enabled:
            return
        self.records.append({
            'task_id': task_id,
            'start': datetime.now().isoformat()
        })
    
    def end_task(self, task_id: str):
        if not self.enabled:
            return
        for r in self.records:
            if r['task_id'] == task_id and 'end' not in r:
                r['end'] = datetime.now().isoformat()
                start = datetime.fromisoformat(r['start'])
                end = datetime.fromisoformat(r['end'])
                duration = (end - start).total_seconds() / 60
                r['duration_min'] = duration
                r['cost_usd'] = round((duration / 60) * self.cost_per_hour, 2)
                
                with open(self.costs_file, 'a') as f:
                    f.write(json.dumps(r) + '\n')
                return r
        return None
    
    def get_summary(self) -> Optional[Dict]:
        if not self.records:
            return None
        total_cost = sum(r.get('cost_usd', 0) for r in self.records)
        total_time = sum(r.get('duration_min', 0) for r in self.records)
        return {
            'tasks': len(self.records),
            'total_cost_usd': round(total_cost, 2),
            'total_time_min': round(total_time, 2)
        }



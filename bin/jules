#!/usr/bin/env python3
"""
Jules - Tool-agnostic unified entry point

Works with: Kilo, OpenCode, Claude Code, Cursor, Generic CLI
"""

import sys
import os
import json
import argparse
from pathlib import Path

# Add lib to path
SCRIPT_DIR = Path(__file__).parent.parent
sys.path.insert(0, str(SCRIPT_DIR / "lib"))

try:
    from tool_adapter import ToolAgnosticOrchestrator, get_adapter
    from background_agent import JulesBackgroundAgent
except ImportError as e:
    print(f"Error: Could not import Jules modules: {e}")
    print(f"Make sure you're running from the correct directory")
    sys.exit(1)


VERSION = "3.0.3"


def print_banner():
    """Print welcome banner"""
    print(f"""
╔════════════════════════════════════════════════════════════╗
║         Jules Orchestrator v{VERSION}                     ║
║         Tool-Agnostic AI Software Factory                  ║
╚════════════════════════════════════════════════════════════╝
""")


def detect_environment():
    """Detect and display current environment"""
    orchestrator = get_adapter()
    env = orchestrator.detect_environment()
    
    print("🔍 Environment Detection")
    print("=" * 60)
    print(f"Tool: {env['tool']}")
    print(f"Adapter: {env['adapter']}")
    print(f"Skill Path: {env['skill_path']}")
    print(f"Supported: {'Yes' if env['is_supported'] else 'No'}")
    print()
    
    if env['context']:
        print("Context:")
        for key, value in env['context'].items():
            print(f"  {key}: {value}")
    
    return env


def install_guide():
    """Show installation guide for detected tool"""
    orchestrator = get_adapter()
    print(orchestrator.get_install_instructions())


def plan_work(prompt: str, repo: str = None, tool: str = None):
    """Plan work - adapts to current tool"""
    if tool:
        os.environ["JULES_TOOL"] = tool
    
    orchestrator = get_adapter()
    
    # Format command for current tool
    command = orchestrator.execute("plan_work", prompt=prompt)
    
    print(f"Executing: {command}")
    print()
    
    # Start the actual agent
    if not repo:
        # Try to detect from git
        try:
            import subprocess
            result = subprocess.run(
                ["git", "remote", "get-url", "origin"],
                capture_output=True, text=True, check=True
            )
            remote = result.stdout.strip()
            # Extract owner/repo from URL
            if "github.com" in remote:
                parts = remote.replace(".git", "").split("/")
                repo = f"{parts[-2]}/{parts[-1]}"
        except:
            pass
    
    if not repo:
        print("❌ Error: Could not detect repository")
        print("   Please specify with --repo owner/repo")
        return
    
    print(f"🚀 Starting orchestration for: {repo}")
    print(f"📝 Prompt: {prompt}")
    print()
    
    # Initialize and start
    try:
        agent = JulesBackgroundAgent(repo, "JULES_MEMORY.json")
        
        # Show what would happen
        print("Actions:")
        print("  1. Generate execution plan with dependencies")
        print("  2. Create GitHub issues for tasks")
        print("  3. Start background monitoring agent")
        print("  4. Auto-approve and merge valid PRs")
        print("  5. Create final PR when complete")
        print()
        
        # For demo, just show status
        print("✅ Plan generated successfully!")
        print(f"📁 Memory file: JULES_MEMORY.json")
        print()
        print("To check status, run:")
        print(f"  jules status --repo {repo}")
        
    except Exception as e:
        print(f"❌ Error: {e}")
        import traceback
        traceback.print_exc()


def show_status(repo: str = None):
    """Show current status"""
    if not repo:
        print("❌ Error: Please specify --repo owner/repo")
        return
    
    try:
        from resume_logic import resume_orchestration
        result = resume_orchestration(repo)
        
        print("📊 Jules Status")
        print("=" * 60)
        print(json.dumps(result, indent=2))
    except Exception as e:
        print(f"❌ Error checking status: {e}")


def resume_work(repo: str = None):
    """Resume from memory"""
    if not repo:
        print("❌ Error: Please specify --repo owner/repo")
        return
    
    print(f"🔄 Resuming orchestration for: {repo}")
    
    try:
        agent = JulesBackgroundAgent(repo, "JULES_MEMORY.json")
        agent.run()
    except KeyboardInterrupt:
        print("\n👋 Stopped by user")
    except Exception as e:
        print(f"❌ Error: {e}")


def main():
    """Main entry point"""
    parser = argparse.ArgumentParser(
        description="Jules Orchestrator - Tool-Agnostic AI Software Factory",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  jules detect                      # Detect environment
  jules plan "Build an API"         # Plan new work
  jules status --repo owner/repo    # Check status
  jules resume --repo owner/repo    # Resume agent
  jules install                     # Show install guide

Supported Tools:
  - Kilo (kilo): /plan-work commands
  - OpenCode: @jules commands
  - Claude Code: Jules: commands
  - Cursor: Command Palette
  - Generic CLI: Direct execution
        """
    )
    
    parser.add_argument(
        "command",
        nargs="?",
        choices=["detect", "plan", "status", "resume", "install", "health", "metrics"],
        default="detect",
        help="Command to execute"
    )
    
    parser.add_argument(
        "prompt",
        nargs="?",
        help="Prompt for plan command"
    )
    
    parser.add_argument(
        "--repo", "-r",
        help="GitHub repository (owner/repo)"
    )
    
    parser.add_argument(
        "--tool", "-t",
        choices=["kilo", "opencode", "claude_code", "cursor", "generic"],
        help="Force specific tool adapter"
    )
    
    parser.add_argument(
        "--version", "-v",
        action="version",
        version=f"Jules Orchestrator v{VERSION}"
    )
    
    args = parser.parse_args()
    
    # Print banner
    if args.command in ["detect", "install"]:
        print_banner()
    
    # Execute command
    if args.command == "detect":
        detect_environment()
    
    elif args.command == "install":
        detect_environment()
        print()
        install_guide()
    
    elif args.command == "plan":
        if not args.prompt:
            parser.error("plan command requires a prompt argument")
        plan_work(args.prompt, args.repo, args.tool)
    
    elif args.command == "status":
        show_status(args.repo)
    
    elif args.command == "resume":
        resume_work(args.repo)
    
    elif args.command == "health":
        print("🏥 Health Dashboard")
        print("=" * 60)
        print("Run 'jules status --repo owner/repo' for health status")
    
    elif args.command == "metrics":
        print("📊 Metrics")
        print("=" * 60)
        print("Metrics available in: .jules/metrics.json")


if __name__ == "__main__":
    main()
